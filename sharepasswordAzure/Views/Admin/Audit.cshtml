@model SharePassword.ViewModels.AdminAuditViewModel
@{
    ViewData["Title"] = "Audit Logs";
}

<h2>Audit Logs</h2>

<form method="get" class="audit-toolbar mb-3">
    <input type="hidden" name="pageSize" value="@Model.PageSize" />

    <div class="audit-toolbar__row">
        <div class="audit-toolbar__search">
            <div class="audit-toolbar__search-input">
                <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search actor, operation, details..." />
            </div>
            <button type="submit" class="btn btn-primary">Search</button>
            @if (!string.IsNullOrWhiteSpace(Model.Search))
            {
                <a class="btn btn-outline-secondary" href="@Url.Action("Audit", new { range = Model.SelectedRange, page = 1, pageSize = Model.PageSize })">Clear</a>
            }
        </div>

        <div class="audit-toolbar__actions">
            <select name="range" class="form-select">
                @foreach (var range in SharePassword.ViewModels.AdminAuditRangeOption.AllValues)
                {
                    <option value="@range" selected="@(range == Model.SelectedRange)">@SharePassword.ViewModels.AdminAuditRangeOption.GetLabel(range)</option>
                }
            </select>
            <button type="submit" class="btn btn-outline-primary" formaction="@Url.Action("ExportAuditJson")" formmethod="get">Export JSON</button>
        </div>
    </div>
</form>

<p class="text-muted">Showing @Model.Logs.Count of @Model.TotalCount events (page @Model.Page of @Model.TotalPages).</p>

<table class="table table-sm table-bordered">
    <thead>
        <tr>
            <th>Time (@ApplicationTime.TimeZoneId)</th>
            <th>Actor</th>
            <th>Operation</th>
            <th>Success</th>
            <th>Target</th>
            <th>IP</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model.Logs)
        {
            <tr>
                <td>@ApplicationTime.FormatUtcForDisplay(log.TimestampUtc)</td>
                <td>@log.ActorType / @log.ActorIdentifier</td>
                <td>@log.Operation</td>
                <td>
                    @if (log.Success)
                    {
                        <span class="badge bg-success">Yes</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">No</span>
                    }
                </td>
                <td>@log.TargetType @log.TargetId</td>
                <td>@log.IpAddress</td>
                <td>@log.Details</td>
            </tr>
        }
    </tbody>
</table>

<nav aria-label="Audit paging">
    <ul class="pagination">
        <li class="page-item @(Model.HasPreviousPage ? string.Empty : "disabled")">
            <a class="page-link" href="@Url.Action("Audit", new { search = Model.Search, range = Model.SelectedRange, page = Model.Page - 1, pageSize = Model.PageSize })">Previous</a>
        </li>
        <li class="page-item disabled">
            <span class="page-link">Page @Model.Page of @Model.TotalPages</span>
        </li>
        <li class="page-item @(Model.HasNextPage ? string.Empty : "disabled")">
            <a class="page-link" href="@Url.Action("Audit", new { search = Model.Search, range = Model.SelectedRange, page = Model.Page + 1, pageSize = Model.PageSize })">Next</a>
        </li>
    </ul>
</nav>
