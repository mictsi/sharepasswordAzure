{
  "Application": {
    "Name": "sharepasswordAzure",
    "EnableHttpsRedirection": true
  },
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://localhost:7099"
      }
    }
  },
  "Storage": {
    "Backend": "sqlite"
  },
  "SqliteStorage": {
    "ConnectionString": "Data Source=App_Data/sharepassword-dev.db",
    "ApplyMigrationsOnStartup": true
  },
  "SqlServerStorage": {
    "ConnectionString": "Server=tcp:sql.example.com,1433;Database=SharePasswordDev;Encrypt=True;TrustServerCertificate=False;User ID=sharepassword_app;Password=ChangeThisPassword!",
    "ApplyMigrationsOnStartup": true
  },
  "PostgresqlStorage": {
    "ConnectionString": "Host=localhost;Port=5432;Database=sharepassword_dev;Username=sharepassword_app;Password=ChangeThisPassword!;SSL Mode=Require;Trust Server Certificate=false",
    "ApplyMigrationsOnStartup": true
  },
  "AzureStorage": {
    "KeyVault": {
      "VaultUri": "",
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "SecretPrefix": "sharepassword"
    },
    "TableAudit": {
      "ServiceSasUrl": "",
      "TableName": "auditlogs",
      "PartitionKey": "audit"
    }
  },
  "AdminAuth": {
    "Username": "admin",
    "PasswordHash": ""
  },
  "OidcAuth": {
    "Enabled": false,
    "Authority": "https://login.example.com",
    "ClientId": "sharepassword-app",
    "ClientSecret": "",
    "LogTokensForTroubleshooting": false,
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc",
    "RequireHttpsMetadata": true,
    "Scopes": [ "openid", "profile", "email" ],
    "GroupClaimType": "groups",
    "AdminRoleName": "Admin",
    "UserRoleName": "User",
    "AdminGroups": [ "<entra-group-id-for-admins>" ],
    "UserGroups": [ "<entra-group-id-for-users>" ]
  },
  "Encryption": {
    "Passphrase": "dev-only-passphrase-change-before-production"
  },
  "Share": {
    "DefaultExpiryHours": 4,
    "CleanupIntervalSeconds": 30
  },
  "ConsoleAuditLogging": {
    "Enabled": true,
    "Level": "DEBUG"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
