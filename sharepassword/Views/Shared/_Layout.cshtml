@using Microsoft.Extensions.Options
@using SharePassword.Options
@using SharePassword.Services
@using System.Security.Claims
@inject IOptions<OidcAuthOptions> OidcAuthOptions
@{
    var adminRoleName = string.IsNullOrWhiteSpace(OidcAuthOptions.Value.AdminRoleName) ? "Admin" : OidcAuthOptions.Value.AdminRoleName.Trim();
    var userRoleName = string.IsNullOrWhiteSpace(OidcAuthOptions.Value.UserRoleName) ? "User" : OidcAuthOptions.Value.UserRoleName.Trim();
    var controllerName = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "home").ToLowerInvariant();
    var actionName = (ViewContext.RouteData.Values["action"]?.ToString() ?? "index").ToLowerInvariant();
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isSharePage = controllerName == "share";
    var isLoginPage = controllerName == "account" && actionName == "login";
    var isAdminShell = isAuthenticated && !isSharePage;
    var canManageShares = User.IsInRole(adminRoleName) || User.IsInRole(userRoleName);
    var canManageAdministration = User.IsInRole(adminRoleName);
    var canAccessAudit = User.IsInRole(adminRoleName) || User.IsInRole(BuiltInRoleNames.Auditor);
    var shellMode = isAdminShell ? "admin" : isLoginPage ? "auth" : "public";
    var widthClass = isAdminShell ? "app-width--admin" : isLoginPage ? "app-width--auth" : "app-width--public";
    var userDisplayName = User.FindFirstValue("preferred_username")
        ?? User.FindFirstValue("email")
        ?? User.FindFirstValue(ClaimTypes.Email)
        ?? User.Identity?.Name
        ?? "Administrator";

    bool IsCurrent(string controller, string action)
    {
        return controllerName == controller.ToLowerInvariant() && actionName == action.ToLowerInvariant();
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SharePassword</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="page-shell page-shell--@shellMode controller-@controllerName action-@actionName">
    <header class="app-chrome app-chrome--@shellMode">
        <div class="app-chrome__inner @widthClass">
            <div class="app-brand-wrap">
                @if (isSharePage)
                {
                    <div class="app-brand" aria-label="SharePassword secure sharing">
                        <img src="~/images/logo.png" alt="SharePassword logo" class="app-brand__logo" />
                        <span>
                            <span class="app-brand__name">SharePassword</span>
                            <span class="app-brand__tag">Secure one-time credential delivery</span>
                        </span>
                    </div>
                }
                else
                {
                    <a class="app-brand" asp-area="" asp-controller="Account" asp-action="@(isAdminShell ? "PostLogin" : "Login")" aria-label="SharePassword home">
                        <img src="~/images/logo.png" alt="SharePassword logo" class="app-brand__logo" />
                        <span>
                            <span class="app-brand__name">SharePassword</span>
                            <span class="app-brand__tag">Secure one-time credential delivery</span>
                        </span>
                    </a>
                }
            </div>

            @if (isAdminShell)
            {
                <div class="dropdown app-adminmenu">
                    <button class="btn app-adminmenu__toggle dropdown-toggle" type="button" id="adminMenuButton" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Open admin menu">
                        <span class="app-adminmenu__icon" aria-hidden="true">
                            <span></span>
                            <span></span>
                            <span></span>
                        </span>
                        <span class="app-adminmenu__label">Admin</span>
                    </button>

                    <div class="dropdown-menu dropdown-menu-end app-adminmenu__menu" aria-labelledby="adminMenuButton">
                        <div class="app-adminmenu__header">
                            <span class="app-adminmenu__eyebrow">Signed in</span>
                            <span class="app-adminmenu__user">@userDisplayName</span>
                        </div>

                        @if (canManageShares)
                        {
                            <div class="app-adminmenu__section-label">Workspace</div>
                            <a class="dropdown-item app-adminmenu__item @(IsCurrent("Admin", "Index") ? "active" : null)" asp-controller="Admin" asp-action="Index" aria-current="@(IsCurrent("Admin", "Index") ? "page" : null)">Dashboard</a>
                            <a class="dropdown-item app-adminmenu__item @(IsCurrent("Admin", "Create") ? "active" : null)" asp-controller="Admin" asp-action="Create" aria-current="@(IsCurrent("Admin", "Create") ? "page" : null)">Create secure share</a>
                        }

                        <div class="app-adminmenu__section-label">Account</div>
                        <a class="dropdown-item app-adminmenu__item @(IsCurrent("Account", "Profile") ? "active" : null)" asp-controller="Account" asp-action="Profile" aria-current="@(IsCurrent("Account", "Profile") ? "page" : null)">My profile</a>

                        @if (canManageAdministration || canAccessAudit)
                        {
                            <div class="dropdown-divider app-adminmenu__divider"></div>
                            <div class="app-adminmenu__section-label">Administration</div>
                        }

                        @if (canManageAdministration)
                        {
                            <a class="dropdown-item app-adminmenu__item @(IsCurrent("Users", "Index") || IsCurrent("Users", "Create") || IsCurrent("Users", "Edit") ? "active" : null)" asp-controller="Users" asp-action="Index">Users</a>
                            <a class="dropdown-item app-adminmenu__item @(IsCurrent("Configuration", "Mail") ? "active" : null)" asp-controller="Configuration" asp-action="Mail">Mail configuration</a>
                            <a class="dropdown-item app-adminmenu__item @(IsCurrent("Configuration", "Settings") ? "active" : null)" asp-controller="Configuration" asp-action="Settings">Settings</a>
                        }

                        @if (canAccessAudit)
                        {
                            <a class="dropdown-item app-adminmenu__item @(IsCurrent("Admin", "Audit") ? "active" : null)" asp-controller="Admin" asp-action="Audit" aria-current="@(IsCurrent("Admin", "Audit") ? "page" : null)">Audit logs</a>
                        }

                        <div class="dropdown-divider app-adminmenu__divider"></div>

                        <form asp-controller="Account" asp-action="Logout" method="post" class="app-adminmenu__form">
                            <button type="submit" class="dropdown-item app-adminmenu__item app-adminmenu__item--danger">Logout</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </header>

    <div class="app-shell__body">
        <main role="main" class="app-stage @widthClass">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="app-footer__inner @widthClass">
            <span>&copy; @ApplicationTime.Now.Year SharePassword</span>
            @if (!isAuthenticated && isSharePage)
            {
                <a class="app-footer__link" asp-controller="Account" asp-action="Login">Admin sign in</a>
            }
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
