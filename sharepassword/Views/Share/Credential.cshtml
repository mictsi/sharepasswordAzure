@model SharePassword.ViewModels.ShareCredentialViewModel
@{
    ViewData["Title"] = "Shared Credentials";

    var expiresLocal = ApplicationTime.ConvertUtcToApplicationTime(Model.ExpiresAtUtc);
    var timeZone = ApplicationTime.TimeZone;
    var fullTimeZoneLabel = $"{timeZone.DisplayName} ({timeZone.Id})";
    var secretMask = new string('*', Math.Max(12, Math.Min(Model.Password.Length, 32)));
}

<section class="public-card public-card--wide">
    <div class="page-eyebrow">Recipient view</div>
    <h1 class="page-title">Shared credentials</h1>
    <p class="page-subtitle">Review the credentials, copy what you need, and then permanently delete the share.</p>

    <section class="surface-card surface-card--info compact-banner">
        <h2 class="surface-card__title">Available until @($"{expiresLocal:MMM dd, yyyy HH:mm}")</h2>
        <p class="surface-card__subtitle">Credentials are deleted after retrieval or expiration.</p>
        <p class="surface-card__subtitle">Time zone: @fullTimeZoneLabel</p>
    </section>

    <textarea id="credentialSecretRaw" class="visually-hidden" readonly aria-hidden="true">@Model.Password</textarea>

    <div class="credential-stack">
        <section class="credential-field">
            <span class="credential-field__label">Username</span>
            <div class="credential-field__row">
                <input id="credentialUsername" class="form-control" value="@Model.Username" readonly />
                <button type="button" class="btn btn-outline-secondary" data-copy-target="credentialUsername" data-copy-success="Username copied">Copy</button>
            </div>
        </section>

        <section class="credential-field">
            <span class="credential-field__label">Password or secret</span>
            <div id="credentialSecret" class="credential-secret" data-secret-source="credentialSecretRaw" data-secret-placeholder="@secretMask">
                <pre class="credential-secret__output" data-secret-output>@secretMask</pre>
            </div>
            <div class="credential-actions">
                <button type="button" class="btn btn-outline-secondary" data-secret-toggle="credentialSecret" data-show-label="Show" data-hide-label="Hide">Show</button>
                <button type="button" class="btn btn-outline-secondary" data-copy-target="credentialSecretRaw" data-copy-success="Secret copied">Copy</button>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.Instructions))
        {
            <section class="credential-field">
                <span class="credential-field__label">Instructions</span>
                <div class="credential-notes">@Model.Instructions</div>
            </section>
        }

        <section class="surface-card surface-card--danger">
            <h2 class="surface-card__title">Delete this share after saving the credentials</h2>
            <p class="surface-card__subtitle">This permanently deletes the shared secret. You will not be able to access it again.</p>
            <p class="mb-3 fw-semibold">I have saved the credentials.</p>
            <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteShareModal">Delete this share permanently</button>
        </section>
    </div>
</section>

<div class="modal fade" id="deleteShareModal" tabindex="-1" aria-labelledby="deleteShareModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="deleteShareModalLabel">Delete shared credentials?</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                This permanently deletes the shared secret. You will not be able to access it again.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="DeleteAfterRetrieve" method="post" class="m-0">
                    <input asp-for="ShareId" type="hidden" />
                    <input asp-for="RecipientEmail" type="hidden" />
                    <button type="submit" class="btn btn-danger">Delete permanently</button>
                </form>
            </div>
        </div>
    </div>
</div>
