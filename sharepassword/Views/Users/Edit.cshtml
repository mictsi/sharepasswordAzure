@model SharePassword.ViewModels.LocalUserEditorViewModel
@{
    ViewData["Title"] = "Manage User";
    const string resetPasswordId = "ResetPassword_NewPassword";

    string FormatStamp(DateTime? value)
    {
        return value.HasValue
            ? $"{ApplicationTime.ConvertUtcToApplicationTime(value.Value):MMM dd, yyyy HH:mm} {ApplicationTime.TimeZoneId}"
            : "Not available";
    }
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Administration</div>
        <h1 class="page-title">Manage local user</h1>
        <p class="page-subtitle">Update the account profile, roles, and enabled state, then reset the password if needed.</p>
    </div>
    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" asp-action="Index">Back to users</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success" role="alert">@Model.StatusMessage</div>
}

@if (Model.IsSeededAdmin)
{
    <div class="alert alert-warning" role="alert">This account is the seeded fallback administrator. The app keeps it as the compatibility bootstrap account.</div>
}

<form method="post" asp-route-id="@Model.Id" class="surface-card form-section">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-grid">
        <div class="field-grid">
            <div>
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" autocomplete="username" />
            </div>
            <div>
                <label asp-for="DisplayName" class="form-label"></label>
                <input asp-for="DisplayName" class="form-control" />
            </div>
            <div>
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" autocomplete="email" />
            </div>
        </div>

        <div class="field-grid">
            <div>
                <span class="form-label d-block">Roles</span>
                <div class="checkbox-grid">
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <label class="toggle-card">
                            <input class="form-check-input" type="checkbox" name="SelectedRoles" value="@role" checked="@(Model.SelectedRoles.Contains(role, StringComparer.OrdinalIgnoreCase))" />
                            <span>@role</span>
                        </label>
                    }
                </div>
            </div>
            <label class="toggle-card">
                <input asp-for="IsDisabled" class="form-check-input" />
                <span>Disable this account</span>
            </label>
            <label class="toggle-card">
                <input asp-for="IsTotpRequired" class="form-check-input" />
                <span>Require authenticator app code at sign-in</span>
            </label>
        </div>
    </div>

    <div class="action-row">
        <button type="submit" class="btn btn-primary">Save changes</button>
    </div>
</form>

<section class="surface-card form-section">
    <div class="form-section__header">
        <h2 class="surface-card__title">User activity</h2>
        <p class="surface-card__subtitle mb-0">Recent login and sharing activity for this account.</p>
    </div>

    <div class="stats-grid">
        <div class="stat-tile">
            <span class="stat-tile__label">Last login</span>
            <span class="stat-tile__value">@FormatStamp(Model.LastLoginAtUtc)</span>
        </div>
        <div class="stat-tile">
            <span class="stat-tile__label">Last share</span>
            <span class="stat-tile__value">@FormatStamp(Model.LastShareCreatedAtUtc)</span>
        </div>
        <div class="stat-tile">
            <span class="stat-tile__label">Successful logins</span>
            <span class="stat-tile__value">@Model.TotalSuccessfulLogins</span>
        </div>
        <div class="stat-tile">
            <span class="stat-tile__label">Shares created</span>
            <span class="stat-tile__value">@Model.TotalSharesCreated</span>
        </div>
    </div>
</section>

<form method="post" asp-action="RemoveTotp" asp-route-id="@Model.Id" class="surface-card form-section" data-confirm="Reset authenticator app setup for this local user?">
    <div class="form-section__header">
        <h2 class="surface-card__title">Authenticator app</h2>
        <p class="surface-card__subtitle mb-0">Reset this account's TOTP setup when the user has lost access to their authenticator app or needs to enroll a new device.</p>
    </div>

    <div class="stats-grid">
        <div class="stat-tile">
            <span class="stat-tile__label">Required</span>
            <span class="stat-tile__value">@(Model.IsTotpRequired ? "Yes" : "No")</span>
        </div>
        <div class="stat-tile">
            <span class="stat-tile__label">Configured</span>
            <span class="stat-tile__value">@(Model.IsTotpConfigured ? "Yes" : "No")</span>
        </div>
    </div>

    <div class="action-row">
        <button type="submit" class="btn btn-outline-danger" disabled="@(!Model.IsTotpConfigured)">Reset authenticator setup</button>
    </div>
</form>

<form method="post" asp-action="ResetPassword" class="surface-card form-section">
    <input type="hidden" name="UserId" value="@Model.ResetPassword!.UserId" />
    <input type="hidden" name="Username" value="@Model.ResetPassword.Username" />

    <div class="form-section__header">
        <h2 class="surface-card__title">Reset password</h2>
        <p class="surface-card__subtitle mb-0">Set a new local password for this user.</p>
    </div>

    <div class="form-grid">
        <div>
            <label for="ResetPassword_NewPassword" class="form-label">New password</label>
            <input id="@resetPasswordId" name="NewPassword" class="form-control" type="password" autocomplete="new-password" required data-password-policy />
            <span asp-validation-for="NewPassword" class="text-danger"></span>
            <partial name="_PasswordStrengthMeter" model="@resetPasswordId" />
        </div>
        <div>
            <label for="ResetPassword_ConfirmPassword" class="form-label">Confirm password</label>
            <input id="ResetPassword_ConfirmPassword" name="ConfirmPassword" class="form-control" type="password" autocomplete="new-password" required data-password-confirm-for="@resetPasswordId" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>
    </div>

    <div class="action-row">
        <button type="submit" class="btn btn-outline-primary">Reset password</button>
    </div>
</form>

<form method="post" asp-action="Delete" asp-route-id="@Model.Id" class="surface-card form-section" data-confirm="Delete this local user? This cannot be undone.">
    <div class="form-section__header">
        <h2 class="surface-card__title">Delete user</h2>
        <p class="surface-card__subtitle mb-0">Remove this local account entirely when it is no longer needed.</p>
    </div>
    <div class="action-row">
        <button type="submit" class="btn btn-outline-danger">Delete user</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
