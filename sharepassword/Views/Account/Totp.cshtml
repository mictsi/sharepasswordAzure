@model SharePassword.ViewModels.TotpVerificationViewModel
@{
    ViewData["Title"] = "Authenticator Code";
}

<section class="auth-card">
    <div class="page-eyebrow">Verification</div>
    <h1 class="page-title">Enter authenticator code</h1>
    <p class="page-subtitle">Use the current 6-digit code from the authenticator app for @Model.Username.</p>

    <form asp-action="Totp" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger app-validation-summary" role="alert"></div>
        <div class="mb-3">
            <label asp-for="Code" class="form-label"></label>
            <input asp-for="Code" class="form-control" inputmode="numeric" autocomplete="one-time-code" maxlength="6" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Verify</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
