@model SharePassword.ViewModels.AdminCreateShareViewModel
@{
    ViewData["Title"] = "Create Password Share";
    var presetOptions = new (int Hours, string Label)[]
    {
        (1, "1 hour"),
        (4, "4 hours"),
        (8, "8 hours"),
        (24, "1 day"),
        (48, "2 days"),
        (72, "3 days"),
        (96, "4 days")
    };
    var selectedExpiryHours = presetOptions.Any(option => option.Hours == Model.ExpiryHours)
        ? Model.ExpiryHours
        : 4;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Step 1</div>
        <h1 class="page-title">Create secure share</h1>
        <p class="page-subtitle">Capture the recipient, the username, and the secret. The link and one-time access code will be shown separately after submission.</p>
    </div>
    <div class="page-header__actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</div>

<form asp-action="Create" method="post" class="create-share-form" data-client-encryption-create>
    <div asp-validation-summary="ModelOnly" class="alert alert-danger app-validation-summary" role="alert"></div>

    <div class="form-grid">
        <section class="surface-card form-section">
            <div class="form-section__header">
                <h2 class="form-section__title">Recipient details</h2>
                <p class="form-section__text">These fields control who receives the share and which account the recipient should expect to use.</p>
            </div>

            <div class="field-grid">
                <div>
                    <label asp-for="RecipientEmail" class="form-label"></label>
                    <input asp-for="RecipientEmail" class="form-control" maxlength="256" autocomplete="email" />
                    <span asp-validation-for="RecipientEmail" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="SharedUsername" class="form-label"></label>
                    <input asp-for="SharedUsername" class="form-control" maxlength="256" autocomplete="username" />
                    <span asp-validation-for="SharedUsername" class="text-danger"></span>
                </div>
            </div>
        </section>

        <section class="surface-card form-section">
            <div class="form-section__header">
                <h2 class="form-section__title">Credentials and guidance</h2>
                <p class="form-section__text">Use the secret field for passwords, API keys, or other one-time credentials. Add instructions only when the recipient needs context.</p>
            </div>

            <div>
                <label asp-for="Password" class="form-label"></label>
                <textarea asp-for="Password" class="form-control" rows="5" maxlength="1000" id="secretText"></textarea>
                <input asp-for="ClientEncryptedPasswordPayload" type="hidden" id="ClientEncryptedPasswordPayload" />
                <div class="field-actions mt-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="clearSecretButton">Clear</button>
                </div>
                <div class="form-text mt-2" id="secretTextCounter">0 / 1000 characters (1000 left)</div>
                <div class="text-danger d-none" id="secretTextWarning">Password or secret is over the 1000 character limit.</div>
                <span asp-validation-for="Password" class="text-danger"></span>
                <span asp-validation-for="ClientEncryptedPasswordPayload" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Instructions" class="form-label"></label>
                <textarea asp-for="Instructions" class="form-control" rows="5" maxlength="1000" id="instructionsText"></textarea>
                <div class="form-text mt-2" id="instructionsTextCounter">0 / 1000 characters (1000 left)</div>
                <div class="text-danger d-none" id="instructionsTextWarning">Instructions are over the 1000 character limit.</div>
                <span asp-validation-for="Instructions" class="text-danger"></span>
            </div>
        </section>

        <section class="surface-card form-section">
            <div class="form-section__header">
                <h2 class="form-section__title">Access controls</h2>
                <p class="form-section__text">Choose how long the share should remain available and whether it also requires Microsoft Entra ID sign-in.</p>
            </div>

            <input asp-for="ExpiryHours" type="hidden" id="ExpiryHours" />

            <div>
                <label class="form-label">Expiration</label>
                <div class="preset-grid">
                    @foreach (var option in presetOptions)
                    {
                        <label class="preset-option">
                            <input class="preset-option__input" type="radio" name="expiryPreset" value="@option.Hours" checked="@(selectedExpiryHours == option.Hours)" />
                            <span class="preset-option__content">@option.Label</span>
                        </label>
                    }
                </div>
                <div class="form-text mt-3">Default access remains 4 hours unless you choose a longer window.</div>
                <span asp-validation-for="ExpiryHours" class="text-danger"></span>
            </div>

            <div class="toggle-card">
                <div class="form-check m-0">
                    @if (Model.IsOidcLoginRequirementAvailable)
                    {
                        <input asp-for="RequireOidcLogin" class="form-check-input" />
                    }
                    else
                    {
                        <input asp-for="RequireOidcLogin" class="form-check-input" disabled="disabled" aria-disabled="true" />
                    }
                </div>
                <div>
                    <label asp-for="RequireOidcLogin" class="form-check-label fw-semibold"></label>
                    @if (Model.IsOidcLoginRequirementAvailable)
                    {
                        <div class="form-text mt-1">Require the signed-in Microsoft Entra ID account to match the recipient email before the access code can be used.</div>
                    }
                    else
                    {
                        <div class="form-text mt-1">Microsoft Entra ID sign-in is disabled in application configuration.</div>
                    }
                    <span asp-validation-for="RequireOidcLogin" class="text-danger"></span>
                </div>
            </div>

            <div class="toggle-card toggle-card--protected">
                <div class="form-check m-0">
                    <input asp-for="UseClientEncryption" class="form-check-input" id="UseClientEncryption" />
                </div>
                <div>
                    <label asp-for="UseClientEncryption" class="form-check-label fw-semibold"></label>
                    <div class="form-text mt-1">Encrypt the secret in this browser before it is sent to the server. The extra password is never stored or sent.</div>
                </div>
            </div>

            <div class="client-encryption-panel @(Model.UseClientEncryption ? null : "d-none")" id="clientEncryptionPanel">
                <div class="field-grid">
                    <div>
                        <label for="extraPassword" class="form-label">Extra password</label>
                        <input type="password" class="form-control" id="extraPassword" autocomplete="new-password" minlength="12" />
                        <div class="form-text mt-2">Share this extra password through a separate channel. Minimum 12 characters.</div>
                    </div>
                    <div>
                        <label for="confirmExtraPassword" class="form-label">Confirm extra password</label>
                        <input type="password" class="form-control" id="confirmExtraPassword" autocomplete="new-password" minlength="12" />
                    </div>
                </div>

                <div class="encryption-status d-none" id="clientEncryptionStatus" role="status" aria-live="polite">
                    <span class="encryption-status__spinner" aria-hidden="true"></span>
                    <span data-encryption-status-text>Encrypting secret...</span>
                </div>
            </div>
        </section>

        <section class="surface-card surface-card--warning form-section">
            <div class="form-section__header">
                <h2 class="form-section__title">Delivery reminder</h2>
                <p class="security-note">The access code is shown once. Send the link and access code through separate channels.</p>
            </div>
            <p class="form-section__text mb-0">Configured time zone: <strong>@ApplicationTime.TimeZoneId</strong>. Current application time: <strong>@ApplicationTime.Now.ToString("yyyy-MM-dd HH:mm:ss zzz")</strong>.</p>
            <div class="action-row">
                <button type="submit" class="btn btn-primary">Create secure share</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </section>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/share-client-encryption.js" asp-append-version="true"></script>
}
